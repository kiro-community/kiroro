# WeCom 部署凭证模板
# 复制此文件为 .env 并填入真实值，.env 已在 .gitignore 中排除
# 使用方式: source .env && sam deploy ...

export WECOM_CORPID=<企业ID>
export WECOM_TOKEN=<回调Token>
export WECOM_ENCODING_AES_KEY=<回调加密密钥>
export WECOM_CORPSECRET=<应用Secret>
export WECOM_AGENTID=<应用ID>
export CERTIFICATE_ARN=arn:aws:acm:us-east-1:<ACCOUNT_ID>:certificate/<CERT_ID>
export CUSTOM_DOMAIN_NAME=<自定义域名>

# 测试脚本用（ChatTest.py）
export WECOM_TOUSER=<接收消息的用户ID>
